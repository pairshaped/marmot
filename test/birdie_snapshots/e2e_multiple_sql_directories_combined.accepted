---
version: 2.0.0
title: e2e multiple sql directories combined
file: ./test/marmot/e2e_test.gleam
test_name: e2e_multiple_sql_directories_test
---
import gleam/dynamic/decode
import sqlight

/// Generated from test_e2e_multi/src/app/sql/find_user.sql
pub type FindUserRow {
  FindUserRow(
    id: Int,
    username: String,
  )
}

/// Generated from test_e2e_multi/src/app/sql/find_user.sql
pub fn find_user(db db: sqlight.Connection, id id: Int) -> Result(List(FindUserRow), sqlight.Error) {
  sqlight.query(
    "SELECT id, username FROM users WHERE id = ?",
    on: db,
    with: [sqlight.int(id)],
    expecting: {
      use id <- decode.field(0, decode.int)
      use username <- decode.field(1, decode.string)
      decode.success(FindUserRow(
        id:,
        username:,
      ))
    },
  )
}

