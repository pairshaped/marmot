---
version: 1.5.5
title: codegen exec only module
file: ./test/marmot/internal/codegen_test.gleam
test_name: codegen_exec_only_module_test
---
import gleam/dynamic/decode
import sqlight

pub fn delete_user(db db: sqlight.Connection, id id: Int) -> Result(List(Nil), sqlight.Error) {
  sqlight.query(
    "DELETE FROM users WHERE id = ?",
    on: db,
    with: [sqlight.int(id)],
    expecting: decode.success(Nil),
  )
}

pub fn delete_all_posts(db db: sqlight.Connection) -> Result(List(Nil), sqlight.Error) {
  sqlight.query(
    "DELETE FROM posts",
    on: db,
    with: [],
    expecting: decode.success(Nil),
  )
}

