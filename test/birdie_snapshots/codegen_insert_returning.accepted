/// Generated from src/app/sql/create_user.sql
pub fn create_user(db db: sqlight.Connection, username username: String, email email: String) -> Result(List(CreateUserRow), sqlight.Error) {
  sqlight.query(
    "INSERT INTO users (username, email) VALUES (?, ?) RETURNING id, created_at",
    on: db,
    with: [sqlight.text(username), sqlight.text(email)],
    expecting: {
      use id <- decode.field(0, decode.int)
      use created_at_raw <- decode.field(1, decode.int)
      decode.success(CreateUserRow(
        id:,
        created_at: timestamp.from_unix_seconds(created_at_raw),
      ))
    },
  )
}
