/// Generated from src/app/sql/find_users_by_age.sql
pub type FindUsersByAgeRow {
  FindUsersByAgeRow(
    id: Int,
    name: String,
  )
}

/// Generated from src/app/sql/find_users_by_age.sql
pub fn find_users_by_age(db db: sqlight.Connection, age_min age_min: Int, age_max age_max: Int) -> Result(List(FindUsersByAgeRow), sqlight.Error) {
  sqlight.query(
    "SELECT id, name FROM users WHERE age > ? AND age < ?",
    on: db,
    with: [sqlight.int(age_min), sqlight.int(age_max)],
    expecting: {
      use id <- decode.field(0, decode.int)
      use name <- decode.field(1, decode.string)
      decode.success(FindUsersByAgeRow(
        id:,
        name:,
      ))
    },
  )
}
