---
version: 1.5.5
title: codegen reserved word column
file: ./test/marmot/internal/codegen_test.gleam
test_name: codegen_reserved_word_column_test
---
pub type FindByTypeRow {
  FindByTypeRow(
    id: Int,
    type_: String,
  )
}

pub fn find_by_type(db db: sqlight.Connection, type_ type_: String) -> Result(List(FindByTypeRow), sqlight.Error) {
  sqlight.query(
    "SELECT id, type FROM items WHERE type = ?",
    on: db,
    with: [sqlight.text(type_)],
    expecting: {
      use id <- decode.field(0, decode.int)
      use type_ <- decode.field(1, decode.string)
      decode.success(FindByTypeRow(
        id:,
        type_:,
      ))
    },
  )
}
