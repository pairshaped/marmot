---
version: 1.5.5
title: codegen select with float
file: ./test/marmot/internal/codegen_test.gleam
test_name: codegen_select_float_test
---
pub type FindProductRow {
  FindProductRow(
    id: Int,
    price: Float,
  )
}

pub fn find_product(db db: sqlight.Connection, id id: Int) -> Result(List(FindProductRow), sqlight.Error) {
  sqlight.query(
    "SELECT id, price FROM products WHERE id = ?",
    on: db,
    with: [sqlight.int(id)],
    expecting: {
      use id <- decode.field(0, decode.int)
      use price <- decode.field(1, decode.float)
      decode.success(FindProductRow(
        id:,
        price:,
      ))
    },
  )
}
