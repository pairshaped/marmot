---
version: 2.0.0
title: codegen timestamp param module with helper
---
import gleam/dynamic/decode
import gleam/time/timestamp.{type Timestamp}
import sqlight

/// Convert a Timestamp to a Unix seconds integer for SQLite storage.
/// Note: sub-second precision is not preserved (nanoseconds are discarded).
fn timestamp_to_int(ts: Timestamp) -> Int {
  let #(s, _) = timestamp.to_unix_seconds_and_nanoseconds(ts)
  s
}

/// Generated from src/app/sql/update_last_seen.sql
pub fn update_last_seen(db db: sqlight.Connection, last_seen last_seen: timestamp.Timestamp, id id: Int) -> Result(List(Nil), sqlight.Error) {
  sqlight.query(
    "UPDATE users SET last_seen = ? WHERE id = ?",
    on: db,
    with: [sqlight.int(timestamp_to_int(last_seen)), sqlight.int(id)],
    expecting: decode.success(Nil),
  )
}

