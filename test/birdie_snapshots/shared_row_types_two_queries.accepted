---
version: 2.0.0
title: shared_row_types_two_queries
---
import gleam/dynamic/decode
import gleam/option.{type Option}
import sqlight

/// Shared return type for queries in this directory:
///   a.sql
///   b.sql
pub type OrgRow {
  OrgRow(
    id: Int,
    name: String,
    bio: Option(String),
  )
}

fn org_row_decoder() -> decode.Decoder(OrgRow) {
  use id <- decode.field(0, decode.int)
  use name <- decode.field(1, decode.string)
  use bio <- decode.field(2, decode.optional(decode.string))
  decode.success(OrgRow(
    id:,
    name:,
    bio:,
  ))
}

/// Generated from a.sql
pub fn get_org(db db: sqlight.Connection, id id: Int) -> Result(List(OrgRow), sqlight.Error) {
  sqlight.query(
    "SELECT id, name, bio FROM orgs WHERE id = @id",
    on: db,
    with: [sqlight.int(id)],
    expecting: org_row_decoder(),
  )
}

/// Generated from b.sql
pub fn list_orgs(db db: sqlight.Connection) -> Result(List(OrgRow), sqlight.Error) {
  sqlight.query(
    "SELECT id, name, bio FROM orgs",
    on: db,
    with: [],
    expecting: org_row_decoder(),
  )
}

