---
version: 1.5.5
title: codegen select with boolean
file: ./test/marmot/internal/codegen_test.gleam
test_name: codegen_select_boolean_test
---
pub type FindActiveUsersRow {
  FindActiveUsersRow(
    id: Int,
    is_active: Bool,
  )
}

pub fn find_active_users(db db: sqlight.Connection) -> Result(List(FindActiveUsersRow), sqlight.Error) {
  sqlight.query(
    "SELECT id, is_active FROM users",
    on: db,
    with: [],
    expecting: {
      use id <- decode.field(0, decode.int)
      use is_active <- decode.field(1, sqlight.decode_bool())
      decode.success(FindActiveUsersRow(
        id:,
        is_active:,
      ))
    },
  )
}
