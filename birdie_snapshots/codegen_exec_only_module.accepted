---
version: 1.5.0
title: codegen exec only module
---
import gleam/dynamic/decode
import sqlight

pub fn delete_user(db: sqlight.Connection, id: Int) {
  sqlight.query(
    "DELETE FROM users WHERE id = ?",
    on: db,
    with: [sqlight.int(id)],
    expecting: decode.success(Nil),
  )
}

pub fn delete_all_posts(db: sqlight.Connection) {
  sqlight.query(
    "DELETE FROM posts",
    on: db,
    with: [],
    expecting: decode.success(Nil),
  )
}

