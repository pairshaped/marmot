---
version: 1.5.5
title: codegen select with blob
file: ./test/marmot/internal/codegen_test.gleam
test_name: codegen_select_blob_test
---
pub type FindAvatarRow {
  FindAvatarRow(
    id: Int,
    avatar: BitArray,
  )
}

pub fn find_avatar(db: sqlight.Connection, id: Int) {
  sqlight.query(
    "SELECT id, avatar FROM users WHERE id = ?",
    on: db,
    with: [sqlight.int(id)],
    expecting: {
      use id <- decode.field(0, decode.int)
      use avatar <- decode.field(1, decode.bit_array)
      decode.success(FindAvatarRow(
        id:,
        avatar:,
      ))
    },
  )
}
