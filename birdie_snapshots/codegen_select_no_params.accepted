---
version: 1.5.0
title: codegen select no params
---
pub type ListUsersRow {
  ListUsersRow(
    id: Int,
    username: String,
  )
}

pub fn list_users(db: sqlight.Connection) {
  sqlight.query(
    "SELECT id, username FROM users",
    on: db,
    with: [],
    expecting: {
      use id <- decode.field(0, decode.int)
      use username <- decode.field(1, decode.string)
      decode.success(ListUsersRow(
        id:,
        username:,
      ))
    },
  )
}
